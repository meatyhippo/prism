# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets (it's in .gitignore).

# --- Database ---

# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://prism:your_secure_password_here@db:5432/prism

# Used by Docker Compose — change to a strong unique password
DB_PASSWORD=your_secure_password_here

# --- Redis ---

REDIS_URL=redis://redis:6379

# --- Application ---

NODE_ENV=production
PORT=3000

# Public URL where users access the dashboard.
# If using HTTPS (recommended): https://your-domain.com or https://your-server-ip
# The setup wizard will help you configure this correctly.
APP_URL=http://localhost:3000

# --- Security Secrets ---
# Generate with: openssl rand -hex 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=generate_a_random_32_character_string_here
PIN_ENCRYPTION_KEY=generate_another_random_32_character_string

# Used for encrypting OAuth tokens at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_64_hex_character_string_here

# --- Google Calendar ---
# Get credentials at: https://console.cloud.google.com
# Enable "Google Calendar API", create OAuth 2.0 Client ID

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Replace localhost:3000 with your APP_URL (e.g. https://your-domain.com)
# Register ALL redirect URIs you use in Google Cloud Console (you can add multiple)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Gmail OAuth redirect for bus tracking (uses same Client ID/Secret as above)
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/google-bus/callback

# --- Apple iCloud/Calendar ---
# Use an APP-SPECIFIC PASSWORD (not your regular password).
# Generate at: https://appleid.apple.com > Security > App-Specific Passwords
# Requires 2FA enabled on your Apple account.

APPLE_ID=your-apple-id@icloud.com
APPLE_APP_PASSWORD=your-app-specific-password

# --- Microsoft (To Do, OneDrive) ---
# Register app at: https://portal.azure.com > App registrations
# Account type: Personal Microsoft accounts only
# API permissions: Tasks.ReadWrite, Files.Read

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# Replace localhost:3000 with your APP_URL (e.g. https://your-domain.com)
# Register ALL redirect URIs you use in Azure (you can add multiple)
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback

# --- Weather (OpenWeatherMap) ---
# Get API key at: https://openweathermap.org/api (free tier: 1000 calls/day)

OPENWEATHER_API_KEY=your-openweathermap-api-key

# City,State,Country (ISO codes) — e.g. Springfield,IL,US or London,GB
WEATHER_LOCATION=Springfield,IL,US

# --- Enphase Solar (Optional) ---
# Get credentials at: https://developer-v4.enphase.com

ENPHASE_API_KEY=your-enphase-api-key
ENPHASE_SYSTEM_ID=your-enphase-system-id

# --- Sonos (Optional) ---
# Get credentials at: https://developer.sonos.com (requires developer approval)

SONOS_CLIENT_ID=your-sonos-client-id
SONOS_CLIENT_SECRET=your-sonos-client-secret
SONOS_REDIRECT_URI=http://localhost:3000/api/auth/sonos/callback

# --- Iframe Embedding (Home Assistant, etc.) ---
# Allow Prism to be embedded in an iframe from specific origins.
# Comma-separated list, or * to allow all origins.
# Example: http://homeassistant.local:8123, https://my-ha.example.com
# ALLOWED_FRAME_ANCESTORS=http://homeassistant.local:8123

# --- Future Integrations (leave blank) ---

# HOMEBRIDGE_URL=http://homebridge-host:8581
# HOMEBRIDGE_USERNAME=admin
# HOMEBRIDGE_PASSWORD=your-homebridge-password

# LIFE360_USERNAME=your-email@example.com
# LIFE360_PASSWORD=your-life360-password
